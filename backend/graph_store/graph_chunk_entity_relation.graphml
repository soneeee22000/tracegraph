<graph edgedefault="undirected"><node id="Graph-Based Retrieval Augmented Generation">
  <data key="d0">Graph-Based Retrieval Augmented Generation</data>
  <data key="d1">concept</data>
  <data key="d2">Graph-Based Retrieval Augmented Generation is a method that combines semantic vector search with structured knowledge graph traversal for knowledge-intensive tasks.</data>
