<node id="Knowledge Retrieval">
  <data key="d0">Knowledge Retrieval</data>
  <data key="d1">concept</data>
  <data key="d2">Knowledge Retrieval encompasses methods and techniques used to obtain relevant information from various sources and documents.</data>
